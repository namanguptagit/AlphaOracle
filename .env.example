# AlphaOracle Environment Configuration

# Locus API (Billing / Wallets)
LOCUS_API_KEY=your_locus_api_key_here

# Firecrawl / Exa API for Scraping (Billed via Locus in production)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# OpenAI API for Reasoning Engine (Billed via Locus in production)
OPENAI_API_KEY=your_openai_api_key_here

# Web3 Private Key (From Locus Agent Wallet) for Executing Trades
AGENT_PRIVATE_KEY=your_0x_private_key_here
POLYGON_RPC_URL=https://polygon-rpc.com/
